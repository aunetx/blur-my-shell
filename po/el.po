#: src/effects/effects.js:202
msgid "Pixelize"
msgstr "Εικονοποίηση"

#: src/effects/effects.js:203
msgid "An effect that pixelizes the image."
msgstr "Ένα εφέ που μετατρέπει την εικόνα σε εικονοστοιχεία."

#: src/effects/effects.js:207 src/effects/effects.js:234
#: src/effects/effects.js:261
msgid "Factor"
msgstr "Παράγοντας"

#: src/effects/effects.js:208 src/effects/effects.js:235
msgid "How much to scale down the image."
msgstr "Πόσο θα μειωθεί η κλίμακα της εικόνας."

#: src/effects/effects.js:215 src/effects/effects.js:242
msgid "Downsampling mode"
msgstr "Λειτουργία υποδειγματοληψίας"

#: src/effects/effects.js:216 src/effects/effects.js:243
msgid "The downsampling method that is used."
msgstr "Η μέθοδος υποδειγματοληψίας που χρησιμοποιείται."

#: src/effects/effects.js:219 src/effects/effects.js:246
msgid "Boxcar"
msgstr "Βαγόνι"

#: src/effects/effects.js:220 src/effects/effects.js:247
msgid "Triangular"
msgstr "Τριγωνικό"

#: src/effects/effects.js:221 src/effects/effects.js:248
msgid "Dirac"
msgstr "Ντιράκ"

#: src/effects/effects.js:229
msgid "Downscale (advanced effect)"
msgstr "Χαμηλότερη κλίμακα (προηγμένο εφέ)"

#: src/effects/effects.js:230
msgid "An effect that downscales the image and put it on the top-left corner."
msgstr ""
"Ένα εφέ που μειώνει την κλίμακα της εικόνας και την τοποθετεί στην επάνω "
"αριστερή γωνία."

#: src/effects/effects.js:256
msgid "Upscale (advanced effect)"
msgstr "Upscale (προηγμένο εφέ)"

#: src/effects/effects.js:257
msgid "An effect that upscales the image from the top-left corner."
msgstr "Ένα εφέ που αναβαθμίζει την εικόνα από την επάνω αριστερή γωνία."

#: src/effects/effects.js:262
msgid "How much to scale up the image."
msgstr "Πόσο θα μεγεθύνετε την εικόνα."

#: src/effects/effects.js:273
msgid "Derivative"
msgstr "Παράγωγο"

#: src/effects/effects.js:274
msgid "Apply a spatial derivative, or a laplacian."
msgstr "Εφαρμόστε μια χωρική παράγωγο ή μια λαπλασιανή."

#: src/effects/effects.js:278
msgid "Operation"
msgstr "πράξη"

#: src/effects/effects.js:279
msgid "The mathematical operation to apply."
msgstr "Η μαθηματική πράξη που θα εφαρμοστεί."

#: src/effects/effects.js:282
msgid "1-step derivative"
msgstr ""

#: src/effects/effects.js:283
msgid "2-step derivative"
msgstr ""

#: src/effects/effects.js:284
msgid "Laplacian"
msgstr ""

#: src/effects/effects.js:292 src/effects/effects.js:297
msgid "Noise"
msgstr ""

#: src/effects/effects.js:293
msgid ""
"An effect that adds a random noise. Prefer the Monte Carlo blur for a more "
"organic effect if needed."
msgstr ""

#: src/effects/effects.js:298
msgid "The amount of noise to add."
msgstr ""

#: src/effects/effects.js:307
msgid "Lightness"
msgstr ""

#: src/effects/effects.js:308
msgid ""
"The luminosity of the noise. A setting of '1.0' will make the effect "
"transparent."
msgstr ""

#: src/effects/effects.js:321
msgid "RGB to HSL (advanced effect)"
msgstr ""

#: src/effects/effects.js:322
msgid "Converts the image from RGBA colorspace to HSLA."
msgstr ""

#: src/effects/effects.js:329
msgid "HSL to RGB (advanced effect)"
msgstr ""

#: src/effects/effects.js:330
msgid "Converts the image from HSLA colorspace to RGBA."
msgstr ""

#: src/effects/effects.js:337
msgid "Corner"
msgstr ""

#: src/effects/effects.js:338
msgid ""
"An effect that draws corners. Add it last not to have the other effects "
"perturb the corners."
msgstr ""

#: src/effects/effects.js:343
msgid "The radius of the corner. GNOME apps use a radius of 12 px by default."
msgstr ""

#: src/effects/effects.js:350
msgid "Top corners"
msgstr ""

#: src/effects/effects.js:351
msgid "Whether or not to round the top corners."
msgstr ""

#: src/effects/effects.js:355
msgid "Bottom corners"
msgstr ""

#: src/effects/effects.js:356
msgid "Whether or not to round the bottom corners."
msgstr ""

#: resources/ui/application-row.ui:4
msgid "Window Name"
msgstr "Όνομα παραθύρου"

#: resources/ui/application-row.ui:8
msgid "Select window"
msgstr "Επιλογή παραθύρου"

#: resources/ui/application-row.ui:9
msgid "Pick a window or select it by its classname."
msgstr "Επιλογή παραθύρου άμεσα ή μέσω του όνοματος κλάσης του (classname)."

#: resources/ui/applications.ui:5
msgid "Applications"
msgstr "Εφαρμογές"

#: resources/ui/applications.ui:10
msgid "Applications blur"
msgstr ""

#: resources/ui/applications.ui:11
msgid ""
"Adds blur to the applications.\n"
"To get the best results possible, although with reduced performances, you "
"can choose the option “No artifact” in the “Other → Hack level” tab."
msgstr ""

#: resources/ui/applications.ui:21 resources/ui/dash.ui:20
#: resources/ui/panel.ui:20
msgid "Blur type"
msgstr ""

#: resources/ui/applications.ui:22
msgid ""
"The dynamic blur is slower and only compatible with a gaussian blur effect, "
"but shows content behind windows."
