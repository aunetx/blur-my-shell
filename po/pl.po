#: resources/ui/application-row.ui:4
msgid "Window Name"
msgstr "Nazwa okna"

#: resources/ui/application-row.ui:8
msgid "Select window"
msgstr "Wybierz okno"

#: resources/ui/application-row.ui:9
msgid "Pick a window or select it by its classname."
msgstr "Wybierz okno lub wskaż je za pomocą nazwy klasowej."

#: resources/ui/applications.ui:5
msgid "Applications"
msgstr "Programy"

#: resources/ui/applications.ui:10
msgid "Applications blur"
msgstr "Rozmycie programów"

#: resources/ui/applications.ui:11
msgid ""
"Adds blur to the applications.\n"
"To get the best results possible, although with reduced performances, you "
"can choose the option “No artifact” in the “Other → Hack level” tab."
msgstr ""
"Dodaje rozmycie do programów.\n"
"Aby uzyskać najlepsze możliwe rezultaty, choć kosztem niższej wydajności, "
"możesz wybrać opcję 'No artifact' w zakładce 'Inne → Poziom hakowania'."

#: resources/ui/applications.ui:21 resources/ui/dash.ui:71
#: resources/ui/other.ui:56 resources/ui/overview.ui:54
#: resources/ui/panel.ui:71
msgid "Sigma"
msgstr "Współczynnik rozmycia"

#: resources/ui/applications.ui:22 resources/ui/dash.ui:72
#: resources/ui/other.ui:57 resources/ui/overview.ui:55
#: resources/ui/panel.ui:72
msgid "The intensity of the blur."
msgstr "Intensywność rozmycia."

#: resources/ui/applications.ui:42 resources/ui/dash.ui:92
#: resources/ui/other.ui:77 resources/ui/overview.ui:75
#: resources/ui/panel.ui:92 src/effects/effects.js:72
#: src/effects/effects.js:101 src/effects/effects.js:138
msgid "Brightness"
msgstr "Jasność"

#: resources/ui/applications.ui:43 resources/ui/dash.ui:93
#: resources/ui/other.ui:78 resources/ui/overview.ui:76
#: resources/ui/panel.ui:93 src/effects/effects.js:73
#: src/effects/effects.js:102 src/effects/effects.js:139
msgid ""
"The brightness of the blur effect, a high value might make the text harder "
"to read."
msgstr "Jasność efektu rozmycia. Wysoka wartość może utrudnić czytanie tekstu."

#: resources/ui/applications.ui:63
msgid "Opacity"
msgstr "Krycie"

#: resources/ui/applications.ui:64
msgid ""
"The opacity of the window on top of the blur effect, a higher value will be "
"more legible."
msgstr ""
"Krycie okna znajdującego się na efekcie rozmycia. Wyższa wartość zwiększy "
"czytelność."

#: resources/ui/applications.ui:85
msgid "Opaque focused window"
msgstr "Nieprzezroczyste aktywne okno"

#: resources/ui/applications.ui:86
msgid ""
"Makes the focused window opaque and the other ones blurred, helping with "
"legibility."
msgstr ""
"Ustawia aktywne okno jako nieprzezroczyste, a pozostałe rozmywa, co pomaga w "
"czytelności."

#: resources/ui/applications.ui:100
msgid "Blur on overview"
msgstr "Rozmycie w widoku przeglądu"

#: resources/ui/applications.ui:101
msgid ""
"Forces the blur to be properly shown on all workspaces on overview.\n"
"This may cause some latency or performance issues."
msgstr ""
"Wymusza poprawne wyświetlanie rozmycia na wszystkich obszarach roboczych w "
"widoku przeglądu.\n"
"Może to powodować pewne opóźnienia lub problemy z wydajnością."

#: resources/ui/applications.ui:116
msgid "Enable all by default"
msgstr "Włącz wszystko domyślnie"

#: resources/ui/applications.ui:117
msgid "Adds blur behind all windows by default."
msgstr "Domyślnie dodaje rozmycie za wszystkimi oknami."

#: resources/ui/applications.ui:133
msgid "Whitelist"
msgstr "Lista dozwolonych"

#: resources/ui/applications.ui:134
msgid "A list of windows to blur."
msgstr "Lista okien do rozmycia."

#: resources/ui/applications.ui:152 resources/ui/applications.ui:189
msgid "Add Window"
msgstr "Dodaj okno"

#: resources/ui/applications.ui:170
msgid "Blacklist"
msgstr "Lista zablokowanych"

#: resources/ui/applications.ui:171
msgid "A list of windows not to blur."
msgstr "Lista okien, których nie należy rozmywać."

#: resources/ui/dash.ui:5
msgid "Dash"
msgstr "Panel szybkiego dostępu"

#: resources/ui/dash.ui:10
msgid "Dash to Dock blur"
msgstr "Rozmycie Dash to Dock"

#: resources/ui/dash.ui:11
msgid "Blur the background of the Dash to Dock extension, if it is used."
msgstr "Rozmyj tło rozszerzenia Dash to Dock, jeśli jest używane."

#: resources/ui/dash.ui:20 resources/ui/panel.ui:20
msgid "Blur type"
msgstr "Typ rozmycia"

#: resources/ui/dash.ui:21 resources/ui/panel.ui:21
msgid ""
"The dynamic blur is slower and only compatible with a gaussian blur effect."
msgstr ""
"Dynamiczne rozmycie jest wolniejsze i jest kompatybilne tylko z efektem "
"rozmycia Gaussa."

#: resources/ui/dash.ui:41 resources/ui/panel.ui:41
msgid "Static"
msgstr "Statyczne"

#: resources/ui/dash.ui:53 resources/ui/panel.ui:53
msgid "Dynamic"
msgstr "Dynamiczne"

#: resources/ui/dash.ui:113 resources/ui/panel.ui:128
msgid "Override background"
msgstr "Nadpisz tło"

#: resources/ui/dash.ui:114
msgid ""
"Makes the background either transparent or semi-transparent, disable this to "
"use Dash to Dock preferences instead."
msgstr ""
"Ustawia tło jako przezroczyste lub półprzezroczyste. Wyłącz to, aby zamiast "
"tego użyć preferencji Dash to Dock."

#: resources/ui/dash.ui:120 resources/ui/panel.ui:136
msgid "Background style"
msgstr "Styl tła"

#: resources/ui/dash.ui:121
msgid "The transparent/semi-transparent style for the dock background."
msgstr "Przezroczysty/półprzezroczysty styl tła paska (docka)."

#: resources/ui/dash.ui:137 resources/ui/panel.ui:167
msgid "Disable in overview"
msgstr "Wyłącz w widoku przeglądu"

#: resources/ui/dash.ui:138
msgid "Disables the blur from Dash to Dock when entering the overview."
msgstr "Wyłącza rozmycie w Dash to Dock po wejściu do widoku przeglądu."

#: resources/ui/dash.ui:167 resources/ui/overview.ui:118
#: resources/ui/overview.ui:138 resources/ui/panel.ui:222
msgid "Transparent"
msgstr "Przezroczyste"

#: resources/ui/dash.ui:168 resources/ui/overview.ui:116
#: resources/ui/overview.ui:139 resources/ui/panel.ui:223
msgid "Light"
msgstr "Jasne"

#: resources/ui/dash.ui:169 resources/ui/overview.ui:117
#: resources/ui/overview.ui:140 resources/ui/panel.ui:224
msgid "Dark"
msgstr "Ciemne"

#: resources/ui/effects-dialog.ui:4
#: src/preferences/pipelines_management/effects_dialog.js:31
msgid "Effects"
msgstr "Efekty"

#: resources/ui/effects-dialog.ui:39
msgid "Add Effect"
msgstr "Dodaj efekt"

#: resources/ui/effects-dialog.ui:72
msgid "Include advanced effects"
msgstr "Włącz zaawansowane efekty"

#: resources/ui/menu.ui:6
msgid "Project page"
msgstr "Strona projektu"

#: resources/ui/menu.ui:10
msgid "Report a Bug"
msgstr "Zgłoś błąd"

#: resources/ui/menu.ui:14
msgid "License"
msgstr "Licencja"

#: resources/ui/menu.ui:18
msgid "Donate"
msgstr "Dotacja"

#: resources/ui/other.ui:5
msgid "Other"
msgstr "Pozostałe"

#: resources/ui/other.ui:10
msgid "Lockscreen blur"
msgstr "Rozmycie ekranu blokady"

#: resources/ui/other.ui:11
msgid "Change the blur of the lockscreen to use this extension's preferences."
msgstr ""
"Zmień rozmycie ekranu blokady, aby używało preferencji tego rozszerzenia."

#: resources/ui/other.ui:28
msgid "Screenshot blur"
msgstr "Rozmycie zrzutu ekranu"

#: resources/ui/other.ui:29
msgid "Add blur to the background of the window selector in the screenshot UI."
msgstr "Dodaj rozmycie do tła selektora okien w interfejsie zrzutów ekranu."

#: resources/ui/other.ui:46
msgid "Window list extension blur"
msgstr "Rozmycie rozszerzenia listy okien"

#: resources/ui/other.ui:47
msgid "Make the window-list extension blurred, if it is used."
msgstr "Rozmyj rozszerzenie listy okien, jeśli jest używane."

#: resources/ui/other.ui:100
msgid "Coverflow Alt-Tab extension blur"
msgstr "Rozmycie rozszerzenia Coverflow Alt-Tab"

#: resources/ui/other.ui:101
msgid "Make the coverflow alt-tab extension blurred, if it is used."
msgstr "Rozmyj rozszerzenie Coverflow Alt-Tab, jeśli jest używane."

#: resources/ui/other.ui:118
msgid "Performance"
msgstr "Wydajność"

#: resources/ui/other.ui:119
msgid "Various options to tweak the performance."
msgstr "Różne opcje dostosowania wydajności."

#: resources/ui/other.ui:123
msgid "Hack level"
msgstr "Poziom hakowania"

#: resources/ui/other.ui:124
msgid ""
"Changes the behaviour of the dynamic blur effect. The default value is "
"highly recommended.\n"
"The “No artifact” option will entirely disable clipped redraws in GNOME "
"shell, and will impact your computer performances significantly."
msgstr ""
"Zmienia zachowanie efektu dynamicznego rozmycia. Wartość domyślna jest "
"zdecydowanie zalecana.\n"
"Opcja 'Brak artefaktów' całkowicie wyłączy w powłoce GNOME wycinane "
"przerysowywanie i znacząco wpłynie na wydajność Twojego komputera."

#: resources/ui/other.ui:138
msgid "Debug"
msgstr "Diagnostyka"

#: resources/ui/other.ui:139
msgid ""
"Makes the extension verbose in logs, activate when you need to report an "
"issue."
msgstr ""
"Sprawia, że rozszerzenie zapisuje szczegółowe informacje w dziennikach. "
"Włącz, gdy chcesz zgłosić problem."

#: resources/ui/other.ui:154
msgid "Reset preferences"
msgstr "Zresetuj preferencje"

#: resources/ui/other.ui:155
msgid "Resets preferences of Blur my Shell irreversibly."
msgstr "Nieodwracalnie resetuje preferencje programu Blur my Shell."

#: resources/ui/other.ui:174
msgid "Reset"
msgstr "Zresetuj"

#: resources/ui/other.ui:203
msgid "High performances"
msgstr "Wysoka wydajność"

#: resources/ui/other.ui:204
msgid "Default"
msgstr "Domyślne"

#: resources/ui/other.ui:205
msgid "No artifact"
msgstr "Brak artefaktów"

#: resources/ui/overview.ui:5
msgid "Overview"
msgstr "Widok przeglądu"

#: resources/ui/overview.ui:10
msgid "Background blur"
msgstr "Rozmycie tła"

#: resources/ui/overview.ui:11
msgid "Add blur to the overview background, using the wallpaper picture."
msgstr "Dodaj rozmycie do tła widoku przeglądu, używając obrazu tła."

#: resources/ui/overview.ui:26
msgid "Overview components style"
msgstr "Styl elementów widoku przeglądu"

#: resources/ui/overview.ui:27
msgid ""
"The semi-transparent style for the dash, search entry/results, and "
"application folders."
msgstr ""
"Półprzezroczysty styl dla Panelu szybkiego dostępu, pola/wyników "
"wyszukiwania oraz folderów programów."

#: resources/ui/overview.ui:44
msgid "Application folder blur"
msgstr "Rozmycie katalogów programów"

#: resources/ui/overview.ui:45
msgid "Makes the background of application folder dialogs blurred."
msgstr "Rozmywa tło okien dialogowych katalogów programów."

#: resources/ui/overview.ui:96
msgid "Application folder dialogs style"
msgstr "Styl okien dialogowych katalogów programów"

#: resources/ui/overview.ui:97
msgid "The semi-transparent style for the application folder dialogs."
msgstr "Półprzezroczysty styl dla okien dialogowych katalogów programów."

#: resources/ui/overview.ui:115 resources/ui/overview.ui:137
msgid "Do not style"
msgstr "Pozostaw domyślny styl"

#: resources/ui/panel.ui:5
msgid "Panel"
msgstr "Panel"

#: resources/ui/panel.ui:10
msgid "Panel blur"
msgstr "Rozmycie panelu"

#: resources/ui/panel.ui:11
msgid "Blur the top panel using the background image."
msgstr "Rozmyj górny panel, używając obrazu tła."

#: resources/ui/panel.ui:113
msgid "Force light text"
msgstr "Wymuś jasny tekst"

#: resources/ui/panel.ui:114
msgid ""
"Use a light text for the panel, useful when using gnome-shell's light theme."
msgstr ""
"Użyj jasnego tekstu dla panelu, przydatne podczas korzystania z jasnego "
"motywu Powłoki GNOME."

#: resources/ui/panel.ui:129
msgid ""
"Override the background of the panel to use a transparent or semi-"
"transparent one.\n"
"Recommended unless you want to customize your GNOME theme."
msgstr ""
"Zastąp tło panelu, aby użyć przezroczystego lub półprzezroczystego. "
"Zalecane, chyba że chcesz dostosować swój motyw GNOME."

#: resources/ui/panel.ui:137
msgid "The transparent/semi-transparent style for the panel background."
msgstr "Przezroczysty/półprzezroczysty styl dla tła panelu."

#: resources/ui/panel.ui:151
msgid "Disable when a window is near"
msgstr "Wyłącz, gdy okno jest w pobliżu"

#: resources/ui/panel.ui:152
msgid "Disables the transparency of the panel when a window is near it."
msgstr "Wyłącza przezroczystość panelu, gdy okno jest w jego pobliżu."

#: resources/ui/panel.ui:168
msgid "Disables the blur from the panel when entering the overview."
msgstr "Wyłącza rozmycie panelu przy wchodzeniu do widoku przeglądu."

#: resources/ui/panel.ui:184
msgid "Compatibility"
msgstr "Zgodność"

#: resources/ui/panel.ui:185
msgid "Various options to provide compatibility with other extensions."
msgstr "Różne opcje zapewnienia zgodności z innymi rozszerzeniami."

#: resources/ui/panel.ui:190
msgid "Hidetopbar extension"
msgstr "Rozszerzenie Hidetopbar"

#: resources/ui/panel.ui:191
msgid "Does not disable the blur in overview, best used with static blur."
msgstr ""
"Nie wyłącza rozmycia w widoku przeglądu, najlepiej używać z rozmyciem "
"statycznym."

#: resources/ui/panel.ui:205
msgid "Blur original panel with Dash to Panel"
msgstr "Rozmyj oryginalny panel z rozszerzeniem Dash to Panel"

#: resources/ui/panel.ui:206
msgid ""
"Enables the blurring of the original panel with Dash to Panel, if selected "
"in the extension's options."
msgstr ""
"Włącza rozmycie oryginalnego panelu z Dash to Panel, jeśli wybrano tę opcję "
"w ustawieniach rozszerzenia."

#: resources/ui/panel.ui:225
msgid "Contrasted"
msgstr "Kontrastowy"

#: resources/ui/pipeline-choose-row.ui:4
msgid "Pipeline"
msgstr "Potok renderowania"

#: resources/ui/pipeline-choose-row.ui:5
msgid "The pipeline to be used with this component."
msgstr "Potok renderowania do użycia z tym komponentem."

#: resources/ui/pipeline-group.ui:6
msgid "Pipeline name"
msgstr "Nazwa potoku renderowania"

#: resources/ui/pipeline-group.ui:20
msgid "Manage effects"
msgstr "Zarządzaj efektami"

#: resources/ui/pipelines.ui:5
msgid "Pipelines"
msgstr "Potoki renderowania"

#: resources/ui/pipelines.ui:10
msgid ""
"Each component uses a pipeline, which can be chosen in the corresponding "
"tab. Here you can create, modify and delete the pipelines and their effects."
msgstr ""
"Każdy komponent używa potoku renderowania, który można wybrać w odpowiedniej "
"zakładce. Tutaj możesz tworzyć, modyfikować i usuwać potoki renderowania "
"oraz ich efekty."

#: resources/ui/pipelines.ui:29
msgid "Add Pipeline"
msgstr "Dodaj potok renderowania"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:9
msgid "The version of the settings to update from."
msgstr "Wersja ustawień, z której ma nastąpić aktualizacja."

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:50
msgid "A dictionnary describing the different pipelines and their effects."
msgstr "Słownik opisujący różne potoki renderowania i ich efekty."

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:55
msgid "Global gaussian sigma to use"
msgstr "Globalny współczynnik rozmycia Gaussa do użycia"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:60
msgid "Global brightness to use"
msgstr "Globalna wartość jasności"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:65
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:137
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:182
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:232
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:307
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:372
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:447
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:492
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:537
msgid "Color to mix with the blur effect"
msgstr "Kolor do zmieszania z efektem rozmycia"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:70
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:142
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:187
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:237
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:312
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:377
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:452
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:497
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:542
msgid "Amount of noise to add to the blur effect"
msgstr "Ilość szumu do dodania do efektu rozmycia"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:75
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:147
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:192
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:242
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:317
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:382
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:457
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:502
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:547
msgid "Lightness of the noise added to the blur effect"
msgstr "Jasność szumu dodawanego do efektu rozmycia"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:80
msgid ""
"Boolean, controls wether or not the color and noise effects are in use "
"globally"
msgstr ""
"Wartość logiczna kontrolująca, czy efekty koloru i szumu są używane globalnie"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:85
msgid ""
"Level of hacks to use (from 0 to 2, 2 disabling clipped redraws entirely)"
msgstr ""
"Poziom poprawek do użycia (od 0 do 2, gdzie 2 całkowicie wyłącza przycinane "
"ponowne rysowania)"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:90
msgid ""
"Boolean, set to true to activate debug mode (more verbose journalctl logs)"
msgstr ""
"Wartość logiczna, ustawiona na 'prawda', aby aktywować tryb debugowania "
"(bardziej szczegółowe dzienniki journalctl)"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:112
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:162
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:207
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:282
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:352
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:422
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:467
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:512
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:557
msgid "Boolean, whether to blur activate the blur for this component or not"
msgstr ""
"Wartość logiczna, określająca, czy aktywować rozmycie dla tego komponentu, "
"czy nie"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:117
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:212
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:287
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:427
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:472
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:517
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:562
msgid ""
"String, the name of the pipeline to use. It must exist, else "
"\"pipeline_default\" will be used"
msgstr ""
"Ciąg znaków, nazwa potoku renderowania do użycia. Musi istnieć, w przeciwnym "
"razie zostanie użyty domyślny"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:122
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:167
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:217
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:292
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:357
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:432
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:477
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:522
msgid ""
"Boolean, whether to customize the blur effect sigma/brightness or use "
"general values"
msgstr ""
"Wartość logiczna, określająca, czy dostosować współczynnik rozmycia/jasność "
"efektu, czy użyć wartości ogólnych"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:127
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:172
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:222
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:297
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:362
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:437
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:482
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:527
msgid "Gaussian sigma to use for the blur effect"
msgstr "Współczynnik rozmycia Gaussa do użycia dla efektu rozmycia"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:132
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:177
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:227
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:302
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:367
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:442
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:487
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:532
msgid "Brightness to use for the blur effect"
msgstr "Jasność do użycia dla efektu rozmycia"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:152
msgid ""
"Enum to select the style of the components in overview (0 not styled, 1 "
"light, 2 dark, 3 transparent)"
msgstr ""
"Wyliczenie do wyboru stylu komponentów w widoku przeglądu (0 brak stylu, 1 "
"jasny, 2 ciemny, 3 przezroczysty)"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:197
msgid ""
"Enum to select the style of the appfolder dialogs (0 not styled, 1 "
"transparent, 2 light, 3 dark)"
msgstr ""
"Wyliczenie do wyboru stylu okien dialogowych katalogów programów (0 brak "
"stylu, 1 przezroczysty, 2 jasny, 3 ciemny)"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:247
msgid "Boolean, whether to use a static or dynamic blur for this component"
msgstr ""
"Wartość logiczna, określająca, czy użyć rozmycia statycznego, czy "
"dynamicznego dla tego komponentu"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:252
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:337
msgid ""
"Boolean, whether to disable blur from this component when opening the "
"overview or not"
msgstr ""
"Wartość logiczna, określająca, czy wyłączyć rozmycie z tego komponentu "
"podczas otwierania widoku przeglądu, czy nie"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:257
msgid ""
"Boolean, whether or not to force the panel to have light text, useful when "
"using light theme"
msgstr ""
"Wartość logiczna, określająca, czy wymusić jasny tekst na panelu, przydatne "
"podczas używania jasnego motywu"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:262
#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:327
msgid "Boolean, whether to override the background or not"
msgstr "Wartość logiczna, określająca, czy zastąpić tło, czy nie"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:267
msgid ""
"Enum to select the style of the panel (0 transparent, 1 light, 2 dark, 3 "
"contrasted)"
msgstr ""
"Wyliczenie do wyboru stylu panelu (0 przezroczysty, 1 jasny, 2 ciemny, 3 "
"kontrastowy)"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:272
msgid ""
"Boolean, whether to disable blur from this component when a window is close "
"to the panel"
msgstr ""
"Wartość logiczna, określająca, czy wyłączyć rozmycie z tego komponentu, gdy "
"okno jest blisko panelu"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:322
msgid "Boolean, whether to use static or dynamic blur for this component"
msgstr ""
"Wartość logiczna, określająca, czy użyć rozmycia statycznego, czy "
"dynamicznego dla tego komponentu"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:332
msgid ""
"Enum to select the style of dash to dock (0 transparent, 1 light, 2 dark)"
msgstr ""
"Wyliczenie do wyboru stylu rozszerzenia Dash to Dock (0 przezroczysty, 1 "
"jasny, 2 ciemny)"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:342
msgid "Radius for the corner rounding effect"
msgstr "Promień dla efektu zaokrąglenia rogów"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:387
msgid "Opacity of the window actor on top of the blur effect"
msgstr "Krycie aktora okna nałożonego na efekt rozmycia"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:392
msgid "Wether or not to make the focused window opaque"
msgstr "Czy uczynić skupione okno nieprzezroczystym, czy nie"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:397
msgid "Wether or not to blur applications on the overview"
msgstr "Czy rozmywać programy w widoku przeglądu, czy nie"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:402
msgid "Wether or not to blur all applications by default"
msgstr "Czy domyślnie rozmywać wszystkie programy, czy nie"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:407
msgid "List of applications to blur"
msgstr "Lista programów do rozmycia"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:412
msgid "List of applications not to blur"
msgstr "Lista programów, których nie należy rozmywać"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:572
msgid ""
"Boolean, whether to try compatibility with hidetopbar@mathieu.bidon.ca or not"
msgstr ""
"Wartość logiczna, określająca, czy próbować zgodności z rozszerzeniem "
"hidetopbar@mathieu.bidon.ca, czy nie"

#: schemas/org.gnome.shell.extensions.blur-my-shell.gschema.xml:582
msgid ""
"Boolean, whether to blur the original panel (if option selected) with Dash "
"to Panel"
msgstr ""
"Wartość logiczna, określająca, czy rozmywać oryginalny panel (jeśli opcja "
"jest wybrana) za pomocą Dash to Panel"

#: src/effects/effects.js:20
msgid "Blur effects"
msgstr "Efekty rozmycia"

#: src/effects/effects.js:28
msgid "Texture effects"
msgstr "Efekty tekstury"

#: src/effects/effects.js:41
msgid "Shape effects"
msgstr "Efekty kształtu"

#: src/effects/effects.js:57
msgid "Native gaussian blur"
msgstr "Natywne rozmycie Gaussa"

#: src/effects/effects.js:58
msgid ""
"An optimized blur effect that smoothly blends pixels within a given radius."
msgstr ""
"Zoptymalizowany efekt rozmycia, który płynnie miesza piksele w określonym "
"promieniu."

#: src/effects/effects.js:62 src/effects/effects.js:91
#: src/effects/effects.js:120 src/effects/effects.js:317
msgid "Radius"
msgstr "Promień"

#: src/effects/effects.js:63
msgid "The intensity of the blur effect."
msgstr "Intensywność efektu rozmycia."

#: src/effects/effects.js:86
msgid "Gaussian blur (advanced effect)"
msgstr "Rozmycie Gaussa (efekt zaawansowany)"

#: src/effects/effects.js:87
msgid ""
"A blur effect that smoothly blends pixels within a given radius. This effect "
"is more precise, but way less optimized."
msgstr ""
"Efekt rozmycia, który płynnie miesza piksele w określonym promieniu. Ten "
"efekt jest bardziej precyzyjny, ale znacznie mniej zoptymalizowany."

#: src/effects/effects.js:92
msgid ""
"The intensity of the blur effect. The bigger it is, the slower it will be."
msgstr ""
"Intensywność efektu rozmycia. Im jest większa, tym wolniejszy będzie (efekt/"
"system)."

#: src/effects/effects.js:115
msgid "Monte Carlo blur"
msgstr "Rozmycie Monte Carlo"

#: src/effects/effects.js:116
msgid ""
"A blur effect that mimics a random walk, by picking pixels further and "
"further away from its origin and mixing them all together."
msgstr ""
"Efekt rozmycia, który naśladuje błądzenie losowe, pobierając piksele coraz "
"bardziej oddalone od punktu początkowego i mieszając je wszystkie razem."

#: src/effects/effects.js:121
msgid ""
"The maximum travel distance for each step in the random walk. A higher value "
"will make the blur more randomized."
msgstr ""
"Maksymalna odległość podróży dla każdego kroku w błądzeniu losowym. Wyższa "
"wartość spowoduje, że rozmycie będzie bardziej losowe."

#: src/effects/effects.js:130
msgid "Iterations"
msgstr "Liczba powtórzeń"

#: src/effects/effects.js:131
msgid "The number of iterations. The more there are, the smoother the blur is."
msgstr "Liczba powtórzeń. Im jest ich więcej, tym płynniejsze jest rozmycie."

#: src/effects/effects.js:148
msgid "Use base pixel"
msgstr "Użyj piksela bazowego"

#: src/effects/effects.js:149
msgid ""
"Whether or not the original pixel is counted for the blur. If it is, the "
"image will be more legible."
msgstr ""
"Czy oryginalny piksel jest wliczany do rozmycia, czy nie. Jeśli tak, obraz "
"będzie bardziej czytelny."

#: src/effects/effects.js:153
msgid "Prefer closer pixels"
msgstr "Preferuj bliższe piksele"

#: src/effects/effects.js:154
msgid ""
"Whether or not the pixels that are closer to the original pixel will have "
"more weight."
msgstr ""
"Czy piksele, które są bliżej oryginalnego piksela, będą miały większą wagę, "
"czy nie."

#: src/effects/effects.js:162 src/effects/effects.js:168
msgid "Color"
msgstr "Kolor"

#: src/effects/effects.js:163
msgid "An effect that blends a color into the pipeline."
msgstr "Efekt, który miesza kolor z potokiem renderowania."

#: src/effects/effects.js:169
msgid ""
"The color to blend in. The blending amount is controled by the opacity of "
"the color."
msgstr ""
"Kolor do zmieszania. Ilość mieszania jest kontrolowana przez krycie koloru."

#: src/effects/effects.js:177
msgid "Pixelize"
msgstr "Pikselizacja"

#: src/effects/effects.js:178
msgid "An effect that pixelizes the image."
msgstr "Efekt, który pikselizuje obraz."

#: src/effects/effects.js:182 src/effects/effects.js:209
#: src/effects/effects.js:236
msgid "Factor"
msgstr "Współczynnik"

#: src/effects/effects.js:183 src/effects/effects.js:210
msgid "How much to scale down the image."
msgstr "O ile zmniejszyć skalę obrazu."

#: src/effects/effects.js:190 src/effects/effects.js:217
msgid "Downsampling mode"
msgstr "Tryb redukcji rozdzielczości"

#: src/effects/effects.js:191 src/effects/effects.js:218
msgid "The downsampling method that is used."
msgstr "Używana metoda trybu redukcji rozdzielczości."

#: src/effects/effects.js:194 src/effects/effects.js:221
msgid "Boxcar"
msgstr "Filtr skrzynkowy"

#: src/effects/effects.js:195 src/effects/effects.js:222
msgid "Triangular"
msgstr "Trójkątny"

#: src/effects/effects.js:196 src/effects/effects.js:223
msgid "Dirac"
msgstr "Diraca"

#: src/effects/effects.js:204
msgid "Downscale (advanced effect)"
msgstr "Redukcja rozdzielczości (efekt zaawansowany)"

#: src/effects/effects.js:205
msgid "An effect that downscales the image and put it on the top-left corner."
msgstr ""
"Efekt, który redukuje rozdzielczość obrazu i umieszcza go w górnym lewym "
"rogu."

#: src/effects/effects.js:231
msgid "Upscale (advanced effect)"
msgstr "Skalowanie w górę (efekt zaawansowany)"

#: src/effects/effects.js:232
msgid "An effect that upscales the image from the top-left corner."
msgstr ""
"Efekt, który skaluje obraz w górę, rozpoczynając od górnego lewego rogu."

#: src/effects/effects.js:237
msgid "How much to scale up the image."
msgstr "Stopień skalowania w górę obrazu."

#: src/effects/effects.js:248
msgid "Derivative"
msgstr "Pochodna"

#: src/effects/effects.js:249
msgid "Apply a spatial derivative, or a laplacian."
msgstr "Zastosuj pochodną przestrzenną lub Laplasjan."

#: src/effects/effects.js:253
msgid "Operation"
msgstr "Operacja"

#: src/effects/effects.js:254
msgid "The mathematical operation to apply."
msgstr "Operacja matematyczna do zastosowania."

#: src/effects/effects.js:257
msgid "1-step derivative"
msgstr "Pochodna 1-krokowa"

#: src/effects/effects.js:258
msgid "2-step derivative"
msgstr "Pochodna 2-krokowa"

#: src/effects/effects.js:259
msgid "Laplacian"
msgstr "Laplasjan"

#: src/effects/effects.js:267 src/effects/effects.js:272
msgid "Noise"
msgstr "Szum"

#: src/effects/effects.js:268
msgid ""
"An effect that adds a random noise. Prefer the Monte Carlo blur for a more "
"organic effect if needed."
msgstr ""
"Efekt, który dodaje losowy szum. Preferuj Rozmycie Monte Carlo, aby uzyskać "
"bardziej organiczny efekt, jeśli to konieczne."

#: src/effects/effects.js:273
msgid "The amount of noise to add."
msgstr "Intensywność szumu."

#: src/effects/effects.js:282
msgid "Lightness"
msgstr "Jasność"

#: src/effects/effects.js:283
msgid ""
"The luminosity of the noise. A setting of '1.0' will make the effect "
"transparent."
msgstr "Jasność szumu. Ustawienie '1.0' sprawi, że efekt będzie przezroczysty."

#: src/effects/effects.js:296
msgid "RGB to HSL (advanced effect)"
msgstr "Konwersja RGB na HSL (efekt zaawansowany)"

#: src/effects/effects.js:297
msgid "Converts the image from RGBA colorspace to HSLA."
msgstr "Konwertuje obraz z przestrzeni barw RGBA na HSLA."

#: src/effects/effects.js:304
msgid "HSL to RGB (advanced effect)"
msgstr "Konwersja HSL na RGB (efekt zaawansowany)"

#: src/effects/effects.js:305
msgid "Converts the image from HSLA colorspace to RGBA."
msgstr "Konwertuje obraz z przestrzeni barw HSLA na RGBA."

#: src/effects/effects.js:312
msgid "Corner"
msgstr "Narożnik"

#: src/effects/effects.js:313
msgid ""
"An effect that draws corners. Add it last not to have the other effects "
"perturb the corners."
msgstr ""
"Efekt, który rysuje narożniki. Dodaj go na końcu, aby inne efekty nie "
"zakłócały narożników."

#: src/effects/effects.js:318
msgid "The radius of the corner. GNOME apps use a radius of 12 px by default."
msgstr "Promień narożnika. Aplikacje GNOME domyślnie używają promienia 12 px."

#: src/effects/effects.js:325
msgid "Top corners"
msgstr "Górne narożniki"

#: src/effects/effects.js:326
msgid "Whether or not to round the top corners."
msgstr "Czy zaokrąglić górne narożniki, czy nie."

#: src/effects/effects.js:330
msgid "Bottom corners"
msgstr "Dolne narożniki"

#: src/effects/effects.js:331
msgid "Whether or not to round the bottom corners."
msgstr "Czy zaokrąglić dolne narożniki, czy nie."

#: src/preferences/pipelines.js:37
#: src/preferences/pipelines_management/pipeline_choose_row.js:64
msgid "New pipeline"
msgstr "Nowy potok renderowania"

#: src/preferences/pipelines_management/pipeline_choose_row.js:28
msgid "Create new pipeline"
msgstr "Utwórz nowy potok renderowania"

#: src/preferences/pipelines_management/pipeline_group.js:84
msgid "No effect"
msgstr "Brak efektu"

#: src/preferences/pipelines_management/pipeline_group.js:86
msgid "1 effect"
msgstr "1 effect"

#: src/preferences/pipelines_management/pipeline_group.js:95
msgid "Unknown effect, "
msgstr "Nieznany efekt, "
